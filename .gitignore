############################################################
# ASP.NET Core / .NET / C# Git Ignore
############################################################

########################
# Build folders
########################
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
publish/
artifacts/

########################
# Visual Studio
########################
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.cache
*.pdb
*.ilk
*.log

########################
# Rider / VS Code
########################
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

########################
# ASP.NET Core
########################
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

########################
# Secrets
########################
secrets.json
*.pfx
*.snk

########################
# IIS / Express
########################
iisexpress/
applicationhost.config

########################
# Logs
########################
logs/
*.log

########################
# Entity Framework
########################
*.mdf
*.ldf

########################
# NuGet
########################
*.nupkg
packages/
!packages/build/
.nuget/

########################
# Node
########################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

########################
# OS Files
########################
.DS_Store
Thumbs.db
desktop.ini

########################
# Temporary Files
########################
*.tmp
*.temp
*.bak
*.backup

########################
# Test Results
########################
TestResults/
*.trx

########################
# Publish Output
########################
wwwroot/dist/
wwwroot/lib/

########################
# Docker
########################
docker-compose.override.yml

########################
# Allow Example Config Files
########################
!appsettings.example.json
!web.example.config

########################
# Keep Assets Folder Tracked
########################
!WebApplicationModel/assets/
!WebApplicationModel/assets/**

########################
# Optional: Ignore Uploaded Files
########################
wwwroot/uploads/
wwwroot/files/